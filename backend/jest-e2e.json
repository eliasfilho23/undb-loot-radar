{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../tests",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "../tests/tsconfig.json" }]
  },
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@/shared/(.*)$": "<rootDir>/../shared/src/$1",
    "^@/shared$"     : "<rootDir>/../shared/src/index.ts",
    "^@/(.*)$"       : "<rootDir>/../backend/src/$1"
  }
}
