{
  "maxConcurrency"     : 1,
  "maxWorkers"         : 1,
  "bail"               : 1,
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir"            : ".",
  "testRegex"          : ".*\\.spec\\.ts$",
  "setupFilesAfterEnv" : ["<rootDir>/jest-setup.ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.json" }]
  },
  "testEnvironment"    : "node",
  "modulePaths"        : ["<rootDir>/node_modules", "<rootDir>/../backend/node_modules"],
  "moduleNameMapper": {
    "^@nestjs/(.*)$"          : "<rootDir>/../backend/node_modules/@nestjs/$1",
    "^@lootradar/shared/(.*)$": "<rootDir>/../shared/src/$1",
    "^@lootradar/shared$"     : "<rootDir>/../shared/src/index.ts",
    "^@/shared/(.*)$"         : "<rootDir>/../shared/src/$1",
    "^@/shared$"              : "<rootDir>/../shared/src/index.ts",
    "^@/(.*)$"                : "<rootDir>/../backend/src/$1"
  },
  "testTimeout": 30000
}
