{
  "compilerOptions": {
    "module"                : "commonjs",
    "moduleResolution"      : "node",
    "target"                : "ES2023",
    "esModuleInterop"       : true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck"          : true,
    "strict"                : true,
    "noImplicitAny"         : false,
    "baseUrl"               : "./"
  },
  "include": ["./**/*.ts"],
  "paths": {
    "@/*": ["./src/*"]
  }
}
